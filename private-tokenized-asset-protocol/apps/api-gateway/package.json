{
  "name": "@tap/api-gateway",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint:api-gateway'",
    "test": "pnpm run build && node --test dist/*.test.js"
  },
  "dependencies": {
    "@tap/attestor-service": "workspace:*",
    "@tap/compliance-engine": "workspace:*",
    "@tap/contracts": "workspace:*",
    "@tap/policy-engine": "workspace:*",
    "@tap/prover-service": "workspace:*",
    "@tap/source-adapters": "workspace:*",
    "@tap/tenant-config": "workspace:*",
    "@tap/shared-types": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
