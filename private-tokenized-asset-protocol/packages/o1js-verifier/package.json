{
  "name": "@tap/o1js-verifier",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tap-o1js-verify": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsc -w -p tsconfig.json",
