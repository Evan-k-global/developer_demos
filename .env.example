# Core network
NODE_ENV=development
PORT=7001
INDEXER_PORT=7002
ZEKO_GRAPHQL_URL=https://testnet.zeko.io/graphql
ZEKO_NETWORK_ID=testnet

# Proof engine mode: crypto (default real cryptographic proof), zk, or mock
PROOF_MODE=crypto
PROVER_SIGNING_KEY=replace-with-strong-secret
# optional overrides for zk mode signer/verifier keys (PEM)
ZK_PROVER_PRIVATE_KEY_PEM=
ZK_PROVER_PUBLIC_KEY_PEM=
# optional external verifier for zk-o1js-proof envelopes
ZK_PROVER_BACKEND=
ZK_O1JS_PROVE_CMD=
ZK_O1JS_VERIFY_CMD=
ZK_O1JS_VERIFICATION_KEY_HASH=
ZK_O1JS_VERIFICATION_KEY_JSON_BASE64=
ZK_O1JS_VERIFIER_MODE=reference-pass-through
ZK_O1JS_MODULE=o1js
ZK_O1JS_REFERENCE_MODE=pass-through
TAP_DATA_DIR=./output
TAP_DATABASE_URL=
TAP_API_KEYS_JSON={"admin_key":{"role":"CONSORTIUM_ADMIN"},"maker_key":{"role":"ISSUER_MAKER","tenantId":"tenant-a"},"checker_key":{"role":"ISSUER_CHECKER","tenantId":"tenant-a"},"checker2_key":{"role":"ISSUER_CHECKER","tenantId":"tenant-a"}}
ZKTLS_REPO_PATH=./external/zk-verify-poc

# Keys (demo placeholders)
FEE_PAYER_PRIVATE_KEY=REPLACE_ME
FEE_PAYER_PUBLIC_KEY=REPLACE_ME
ZKAPP_PRIVATE_KEY=REPLACE_ME
ZKAPP_PUBLIC_KEY=REPLACE_ME
SPONSOR_PRIVATE_KEY=REPLACE_ME

# Attestation
TLSNOTARY_SIGNING_KEY_HEX=REPLACE_ME
PHONE_VERIFICATION_PROVIDER=mock
BANK_STATEMENT_PROVIDER=upload
PERSONA_API_KEY=
PERSONA_BASE_URL=https://withpersona.com
PERSONA_WEBHOOK_SECRET=
PERSONA_WEBHOOK_TOLERANCE_SEC=300
CUSTODY_API_KEY=
CUSTODY_BASE_URL=https://sandbox.custody.example
CUSTODY_WEBHOOK_SECRET=
CUSTODY_WEBHOOK_TOLERANCE_SEC=300

# Reliability
TAP_SOURCE_CB_FAILURE_THRESHOLD=3
TAP_SOURCE_CB_OPEN_MS=30000
TAP_SOURCE_FAILOVER_ORDER_JSON=
TAP_SOURCE_ROUTING_STRATEGY=ordered
TAP_SOURCE_ROUTING_WEIGHTS_JSON=
TAP_SOURCE_RETRY_BUDGET_PER_HOUR=100
TAP_SOURCE_RETRY_MAX_ATTEMPTS=3
TAP_SOURCE_RETRY_BASE_DELAY_MS=3000
TAP_SOURCE_RETRY_WORKER_ENABLED=1
TAP_SOURCE_RETRY_WORKER_INTERVAL_MS=2000
TAP_SOURCE_RETRY_WORKER_BATCH_SIZE=5
TAP_SETTLEMENT_RECONCILE_WORKER_ENABLED=0
TAP_SETTLEMENT_RECONCILE_WORKER_INTERVAL_MS=15000
TAP_SETTLEMENT_RECONCILE_WORKER_LIMIT=200
TAP_SETTLEMENT_RECONCILE_STALE_MINUTES=15
TAP_SETTLEMENT_RECONCILE_MAX_ACTIONS_PER_RUN=200
TAP_SETTLEMENT_RECONCILE_FAILURE_BUDGET_PER_HOUR=20
TAP_SETTLEMENT_RECONCILE_PAUSE_MINUTES_ON_BUDGET_EXCEEDED=30
TAP_SETTLEMENT_RECONCILE_ALERT_WEBHOOK_URL=
TAP_SETTLEMENT_RECONCILE_SLACK_WEBHOOK_URL=
TAP_SETTLEMENT_RECONCILE_ALLOW_FINALIZE_MISSING_TIMESTAMP=1
TAP_SETTLEMENT_RECONCILE_ALLOW_RETRY_PENDING_SUBMIT=1
TAP_SETTLEMENT_RECONCILE_ALLOW_PROMOTE_SUBMITTED_RECORDED=1
TAP_SETTLEMENT_RECONCILE_ALLOW_MARK_SUBMITTED_FAILED=1
TAP_ISSUER_APPROVAL_EXPIRY_MINUTES=1440
TAP_ISSUER_DUAL_APPROVAL_THRESHOLD_CENTS=0
TAP_ISSUER_REQUIRE_REASON_CODE=0
TAP_ISSUER_ALLOWED_REASON_CODES=
TAP_CERTIFICATION_SIGNING_KEY=
CERT_INDEX_MAX=200

# Ethereum bridge
ETH_RPC_URL=https://sepolia.infura.io/v3/REPLACE_ME
ETH_CHAIN_ID=11155111
L1_BRIDGE_CONTRACT=0x0000000000000000000000000000000000000000
PUBLIC_STABLECOIN_CONTRACT=0x0000000000000000000000000000000000000000

# UI config
VITE_API_BASE_URL=http://localhost:7001
VITE_INDEXER_BASE_URL=http://localhost:7002
